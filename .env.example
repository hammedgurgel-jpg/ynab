# Copie este arquivo para ".env" e preencha com os dados do SEU projeto Supabase.
# Você encontra os dois valores em: Supabase → Project Settings → API.
# A "anon key" é pública e pode ficar no frontend; a privacidade dos dados é garantida pelo RLS.
# NUNCA use aqui a "service_role key".

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
